int insert_specific(int ar[],int ln,int pos)             //specificP_input
{
    int item;
    printf("\nEnter the number : ");
    scanf("%d",&item);
    for (int i = ln - 1;i >= pos; i--){
    ar[i+1] = ar[i];
    }
    ar[pos] = item;
    printf("%d added in %d position\n",item,pos);
    return ln + 1;
}
void linear_scarch(int ar[],int n,int v){
    int count = 0;
    for(int i = 0; i < n; ++i){
        if(ar[i] == v){
            count++;
        }
    }
    if(count == 0){
        printf("Not Found\n");
    }
    else{
        printf("Total found : %d\n",count);
    }
}
void bubblesort(int ar[],int n,int ln)
{
    for(int i = 0; i < n; ++i){
        for(int j = 0; j <= n-i; ++j){
            if(ar[j] > ar[i]){
                int temp  = ar[j+1];
                ar[j+1] = ar[i];
                ar[i] = ar[j+1];
            }
        }
    }
}
